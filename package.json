{
  "name": "wpe-favorites",
  "version": "1.0.8",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "vite build && cross-env BUILD_TARGET=admin-docs vite build && cross-env BUILD_TARGET=admin-settings vite build",
    "build:frontend": "vite build",
    "build:docs": "cross-env BUILD_TARGET=admin-docs vite build",
    "build:settings": "cross-env BUILD_TARGET=admin-settings vite build",
    "watch": "vite build --watch",
    "watch:docs": "cross-env BUILD_TARGET=admin-docs vite build --watch",
    "watch:settings": "cross-env BUILD_TARGET=admin-settings vite build --watch",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^6.2.1",
    "@tsconfig/svelte": "^5.0.6",
    "cross-env": "^10.1.0",
    "svelte": "^5.43.8",
    "svelte-check": "^4.3.4",
    "typescript": "^5.7.0",
    "vite": "^6.0.0"
  }
}
